<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem" met="[6pp]+6pp/6pp/6pp+6pp">
        <lg type="strophe" met="[6pp]+6pp/6pp/6pp+6pp" rhyme="a+b/b/a+b">
          <l n="4">
            <seg type="hemistich">
              <w>[...]trarium</w>
            </seg>
            <seg type="hemistich">
              <w>ab</w>
              <w>hoste</w>
              <w>nescio</w>
            </seg>
          </l>
          <l n="5">
            <w>fit</w>
            <w>hic</w>
            <w>provisio</w>
            <pc resp="#editor">:</pc>
          </l>
          <l n="6">
            <seg type="hemistich">
              <w>in</w>
              <w>hoc</w>
              <w>adiutorium</w>
            </seg>
            <seg type="hemistich">
              <w>felix</w>
              <w>audicio</w>
              <pc resp="#editor">!</pc>
            </seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
