<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem" met="I-IV:3x(7pp+6p), Ref.: 6p/7pp+6p">
        <lg type="strophe" n="I" met="7pp+6p/7pp+6p/7pp+6p" rhyme="a+b/a+b/a+b">
          <l n="1">
            <seg type="hemistich">
              <w>Ecce</w>
              <w>torpet</w>
              <w>probitas</w>
              <pc resp="#editor">,</pc>
            </seg>
            <seg type="hemistich">
              <w>virtus</w>
              <w>sepelitur</w>
              <pc resp="#editor">;</pc>
            </seg>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>fit</w>
              <w>iam</w>
              <w>parca</w>
              <w>largitas</w>
              <pc resp="#editor">,</pc>
            </seg>
            <seg type="hemistich">
              <w>parcitas</w>
              <w>largitur</w>
              <pc resp="#editor">;</pc>
            </seg>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>verum</w>
              <w>dicit</w>
              <w>falsitas</w>
              <pc resp="#editor">,</pc>
            </seg>
            <seg type="hemistich">
              <w>veritas</w>
              <w>mentitur</w>
              <pc>&#183;</pc>
              <pc resp="#editor">.</pc>
            </seg>
          </l>
        </lg>
        <lg type="refrain" met="6p/7pp+6p" rhyme="A/b+A">
          <head>[Refl.]</head>
          <l n="1">
            <w>Omnes</w>
            <app type="text">
              <lem>
                <w>iura</w>
              </lem>
              <note>i- atramento oblita</note>
            </app>
            <w>ledunt</w>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>et</w>
              <w>ad</w>
              <w>res</w>
              <w>illicitas</w>
            </seg>
            <seg type="hemistich">
              <w>liciter</w>
              <w>accedunt</w>
              <pc>&#183;</pc>
              <pc resp="#editor">.</pc>
            </seg>
          </l>
        </lg>
        <lg type="strophe" n="II" met="7pp+6p/7pp+6p/7pp+6p" rhyme="a+b/a+b/a+b">
          <l n="1">
            <seg type="hemistich">
              <w>Regnat</w>
              <w>avaricia</w>
              <pc resp="#editor">,</pc>
            </seg>
            <seg type="hemistich">
              <w>regnant</w>
              <w>et</w>
              <app type="text">
                <lem>
                  <w>avari</w>
                </lem>
                <note>corr. ex <w>avaria</w> cod.</note>
              </app>
              <pc resp="#editor">;</pc>
            </seg>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>mente</w>
              <w>quivis</w>
              <app type="text">
                <lem wit="CB O Om HSB V Tc T">
                  <w>anxia</w>
                </lem>
                <rdg wit="cod."><w>noxia</w></rdg>
              </app>
            </seg>
            <seg type="hemistich">
              <w>nititur</w>
              <w>ditari</w>
              <pc resp="#editor">,</pc>
            </seg>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>cum</w>
              <w>sit</w>
              <w>summa</w>
              <w>gloria</w>
            </seg>
            <seg type="hemistich">
              <w>censu</w>
              <w>gloriari</w>
              <pc>&#183;</pc>
              <pc resp="#editor">.</pc>
            </seg>
          </l>
        </lg>
        <lg type="refrain" met="[6p]" rhyme="A">
          <head>[Refl.]</head>
          <l n="1">
            <w>Omnes</w>
            <pc>&#183;</pc>
            <pc resp="#editor">...</pc>
          </l>
        </lg>
        <lg type="strophe" n="III" met="7pp+6p/7pp+6p/7pp+6p" rhyme="a+b/a+b/a+b">
          <l n="1">
            <seg type="hemistich">
              <w>Multum</w>
              <w>habet</w>
              <w>oneris</w>
            </seg>
            <seg type="hemistich">
              <pc resp="#editor" pre="true">&#8216;</pc>
              <w>do</w>
              <w>das</w>
              <w>dedi</w>
              <w>dare</w>
              <pc resp="#editor">&#8217;;</pc>
            </seg>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>verbum</w>
              <w>hoc</w>
              <w>pre</w>
              <w>ceteris</w>
            </seg>
            <seg type="hemistich">
              <w>volunt</w>
              <w>ignorare</w>
            </seg>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>divites</w>
              <pc resp="#editor">,</pc>
              <w>quos</w>
              <w>poteris</w>
            </seg>
            <seg type="hemistich">
              <w>mari</w>
              <w>comparare</w>
              <pc>&#183;</pc>
              <pc resp="#editor">.</pc>
            </seg>
          </l>
        </lg>
        <lg type="refrain" met="[6p]" rhyme="A">
          <head>[Refl.]</head>
          <l n="1">
            <w>O[mnes]</w>
            <pc>&#183;</pc>
            <pc resp="#editor">...</pc>
          </l>
        </lg>
        <lg type="strophe" n="IV" met="7pp+6p/7pp+6p/7pp+6p" rhyme="a+b/a+b/a+b">
          <l n="1">
            <seg type="hemistich">
              <app type="text">
                <lem wit="HSB V Tc T">
                  <w>Cunctis</w>
                </lem>
                <rdg wit="cod."><w>cuntis</w></rdg>
              </app>
              <w>est</w>
              <w>equaliter</w>
            </seg>
            <seg type="hemistich">
              <w>insita</w>
              <w>cupido</w>
              <pc resp="#editor">;</pc>
            </seg>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>perit</w>
              <w>fides</w>
              <w>turpiter</w>
              <pc resp="#editor">,</pc>
            </seg>
            <seg type="hemistich">
              <w>nullus</w>
              <w>fidus</w>
              <w>fido</w>
              <pc resp="#editor">,</pc>
            </seg>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>nec</w>
              <w>Iunoni</w>
              <w>Iupiter</w>
            </seg>
            <seg type="hemistich">
              <w>nec</w>
              <w>Enee</w>
              <w>Dido</w>
              <pc>&#183;</pc>
              <pc resp="#editor">.</pc>
            </seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
</TEI>