<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I">
          <l n="1">
            <seg type="hemistich">Adieu l&#8217;horrible saison,</seg>
            <seg type="hemistich">le froid hivernal ;</seg>
          </l>
          <l n="2">
            <seg type="hemistich">revient, c&#8217;est vraiment plaisant,</seg>
            <seg type="hemistich">le temps estival,</seg>
          </l>
          <l n="3">
            <seg type="hemistich">que l&#8217;Amour revendique</seg>
            <seg type="hemistich">comme lui appartenant,</seg>
          </l>
          <l n="4">
            <seg type="hemistich">et donc qui aime l&#8217;Amour,</seg>
            <seg type="hemistich">qu&#8217;il fasse f&#234;te au printemps.</seg>
          </l>
        </lg>
        <lg type="strophe" n="II">
          <l n="1">
            <seg type="hemistich">La saison ayant chang&#233;,</seg>
            <seg type="hemistich">la terre porte des fleurs,</seg>
          </l>
          <l n="2">
            <seg type="hemistich">et pour les diverses fleurs</seg>
            <seg type="hemistich">en varie les couleurs.</seg>
          </l>
          <l n="3">
            <seg type="hemistich">De ces couleurs vari&#233;es</seg>
            <seg type="hemistich">les pr&#233;s sont tout parfum&#233;s,</seg>
          </l>
          <l n="4">
            <seg type="hemistich">le rossignol par ses chants</seg>
            <seg type="hemistich">fait na&#238;tre maintes amours.</seg>
          </l>
        </lg>
        <lg type="strophe" n="III">
          <l n="1">
            <seg type="hemistich">Quiconque aime, qu&#8217;il se plaise</seg>
            <seg type="hemistich">&#224; voir la saison</seg>
          </l>
          <l n="2">
            <seg type="hemistich">o&#249; il va enfin pouvoir</seg>
            <seg type="hemistich">trouver le bonheur,</seg>
          </l>
          <l n="3">
            <seg type="hemistich">et puisque l&#8217;Amour fleurit,</seg>
            <seg type="hemistich">qui veut qu&#8217;on soit joyeux,</seg>
          </l>
          <l n="4">
            <seg type="hemistich">que personne parmi nous</seg>
            <seg type="hemistich">n&#8217;ose &#234;tre malheureux.</seg>
          </l>
        </lg>
        <lg type="strophe" n="IV">
          <l n="1">
            <seg type="hemistich">&#8211; Je demande seulement</seg>
            <seg type="hemistich">qu&#8217;une me soit donn&#233;e,</seg>
          </l>
          <l n="2">
            <seg type="hemistich">celle-l&#224; dont le baiser</seg>
            <seg type="hemistich">peut m&#8217;&#233;viter la mort.</seg>
          </l>
          <l n="3">
            <seg type="hemistich">Par le lien de l&#8217;amour</seg>
            <seg type="hemistich">je veux lui &#234;tre attach&#233;.</seg>
          </l>
          <l n="4">
            <seg type="hemistich">Il est doux d&#8217;accepter</seg>
            <seg type="hemistich">d&#8217;&#234;tre par ce trait bless&#233; !</seg>
          </l>
        </lg>
        <lg type="strophe" n="V">
          <l n="1">
            <seg type="hemistich">Si je ris apr&#232;s la blessure,</seg>
            <seg type="hemistich">douce sera la blessure.</seg>
          </l>
          <l n="2">
            <seg type="hemistich">Si je pleure apr&#232;s ce rire,</seg>
            <seg type="hemistich">c&#8217;est la loi de nature.</seg>
          </l>
          <l n="3">
            <seg type="hemistich">Mais quand sera advenue</seg>
            <seg type="hemistich">la vieillesse si dure,</seg>
          </l>
          <l n="4">
            <seg type="hemistich">je pleurerai d&#8217;avoir aim&#233;,</seg>
            <seg type="hemistich">vu la douleur future.</seg>
          </l>
        </lg>
        <lg type="strophe" n="VI">
          <l n="1">
            <seg type="hemistich">Le fait que je l&#8217;aime ainsi,</seg>
            <seg type="hemistich">c&#8217;est bien incroyable :</seg>
          </l>
          <l n="2">
            <seg type="hemistich">c&#8217;est un poids qui me ligote,</seg>
            <seg type="hemistich">presqu&#8217;insupportable.</seg>
          </l>
          <l n="3">
            <seg type="hemistich">Je suis s&#251;r qu&#8217;&#224; mon sujet</seg>
            <seg type="hemistich">un seul fait est vrai :</seg>
          </l>
          <l n="4">
            <seg type="hemistich">je meurs si ne m&#8217;est donn&#233;e</seg>
            <seg type="hemistich">celle que j&#8217;ai pr&#233;f&#233;r&#233;e.</seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
</TEI>