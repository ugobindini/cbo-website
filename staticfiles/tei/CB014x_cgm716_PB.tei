    <body>
      <div type="sequence">
        <lg type="versicle" n="1a">
          <l n="1">Nagu&#232;re ignorant les pleurs,</l>
          <l n="2">me voici bris&#233;e de plaintes,</l>
          <l n="3">crucifi&#233;e par la douleur.</l>
        </lg>
        <lg type="versicle" n="1b">
          <l n="1">Les Juifs ont priv&#233; la terre</l>
          <l n="2">de sa lumi&#232;re, moi de mon fils,</l>
          <l n="3">de ma joie, de mon bonheur.</l>
        </lg>
      </div>
