  <text>
    <body>
      <div type="poem">
        <lg type="strophe">
          <l n="1" rend="indent(1)">Je m&#8217;&#233;tais soumis</l>
          <l n="2" rend="indent(1)">&#224; la dure loi</l>
          <l n="3" rend="indent(1)">d&#8217;une vie perdue,</l>
          <l n="4" rend="indent(1)">scandaleusement</l>
          <l n="5" rend="indent(1)">lorsque j&#8217;ai bris&#233;</l>
          <l n="6" rend="indent(1)">mes engagements.</l>
          <l n="7">Mais au soir de ma vie,</l>
          <l n="8">j&#8217;ai choisi d&#8217;amender</l>
          <l n="9">tout ce qu&#8217;auparavant</l>
          <l n="10">j&#8217;ai fait comme un enfant.</l>
        </lg>
      </div>
    </body>
  </text>
