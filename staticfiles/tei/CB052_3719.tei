          <l n="4">
            <seg type="hemistich">
              <w>hic</w>
              <w>super</w>
              <w>apostolos</w>
            </seg>
            <seg type="hemistich">
              <w>spiritus</w>
              <w>intonuit</w>
              <pc resp="#editor">.</pc>
            </seg>
