            </seg>
          </l>
          <l n="2">
            <w>canticum</w>
            <w>leticie</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>ac</w>
              <w>reddamus</w>
            </seg>
            <seg type="hemistich">
              <w>quas</w>
              <w>debemus</w>
            </seg>
          </l>
          <l n="4">
            <w>laudes</w>
            <w>regi</w>
            <w>glorie</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="5">
            <seg type="hemistich">
              <w>qui</w>
              <w>salvavit</w>
            </seg>
            <seg type="hemistich">
              <w>urbem</w>
              <w>Davit</w>
            </seg>
          </l>
          <l n="6">
            <w>a</w>
            <w>paganis</w>
            <w>hodie</w>
            <pc resp="#editor">.</pc>
          </l>
        </lg>
        <lg type="refrain" met="5pp/6pp/7pp/7pp/7pp/8pp/8pp/8pp" rhyme="A/A/A/A/A/A/A/A">
          <head>[R.]</head>
          <l n="1">
            <w>Festum</w>
            <w>agitur</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="2">
            <w>dies</w>
            <w>recolitur</w>
          </l>
          <l n="3">
            <w>in</w>
            <w>qua</w>
            <w>Dagon</w>
            <w>frangitur</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="4">
            <w>et</w>
