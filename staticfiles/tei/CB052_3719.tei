              <w>sollemnibus</w>
            </seg>
            <seg type="hemistich">
              <w>trait</w>
              <w>Solemniacum</w>
              <pc resp="#editor">;</pc>
            </seg>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>sollemnizent</w>
              <w>igitur</w>
            </seg>
            <seg type="hemistich">
              <w>omnes</w>
              <w>preter</w>
              <w>monacum</w>
              <pc resp="#editor">,</pc>
            </seg>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>qui</w>
              <w>sibi</w>
              <w>virilia</w>
            </seg>
            <seg type="hemistich">
              <w>resecavit</w>
              <w>serra</w>
              <w>cum</w>
