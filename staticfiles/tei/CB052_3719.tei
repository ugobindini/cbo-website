            <seg type="hemistich">
              <w>Hec</w>
              <w>urbs</w>
              <w>nobilissima</w>
            </seg>
            <seg type="hemistich">
              <w>prima</w>
              <w>regem</w>
              <w>habuit</w>
              <pc resp="#editor">,</pc>
            </seg>
          </l>
          <l n="2">
            <seg type="hemistich">
              <w>in</w>
              <w>hac</w>
              <w>urbe</w>
              <w>maxima</w>
            </seg>
            <seg type="hemistich">
              <w>Domino</w>
              <w>complacuit</w>
              <pc resp="#editor">,</pc>
            </seg>
          </l>
          <l n="3">
            <seg type="hemistich">
              <w>in</w>
