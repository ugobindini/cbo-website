            </seg>
          </l>
          <l n="5">
            <seg type="hemistich">
              <w>ipse</w>
              <w>solus</w>
              <w>lugeat</w>
            </seg>
            <seg type="hemistich">
              <w>reus</w>
              <w>apud</w>
              <w>Eacum</w>
              <pc resp="#editor">!</pc>
            </seg>
          </l>
        </lg>
        <lg type="strophe" n="II" met="4p+4p/7pp/4p+4p/7pp/4p+4p/7pp" rhyme="a+a/b/c+c/b/d+d/b">
